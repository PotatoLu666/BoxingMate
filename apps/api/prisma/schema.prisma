generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  name          String?
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  nickname      String?
  avatarUrl     String?
  height        Float?
  weight        Float?
  age           Int?
  gender        String?
  fightStyle    String?
  bio           String?
  city          String?
  gym           String?

  trainingSessions TrainingSession[]
  dailyCheckIns    DailyCheckIn[]
}

model VerificationCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model TrainingSession {
  id            String   @id @default(uuid())
  userId        String
  date          DateTime
  type          String   // boxing, muay_thai, mma, kickboxing, sparring, conditioning
  duration      Int      // total minutes
  rounds        Int?
  roundDuration Int?     // seconds per round
  restDuration  Int?     // seconds rest between rounds
  intensity     String?  // low, medium, high
  notes         String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model DailyCheckIn {
  id        String   @id @default(uuid())
  userId    String
  date      DateTime // date only (start of day)
  weight    Float?
  mood      String?  // great, good, okay, bad, terrible
  energy    String?  // high, medium, low
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}
